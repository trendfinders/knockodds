# WordPress Database
WP_DB_PASSWORD=your_secure_password_here
WP_DB_ROOT_PASSWORD=your_root_password_here

# Debug mode (set to true for development)
WP_DEBUG=false

# Frontend URL for ISR revalidation webhooks
FRONTEND_URL=http://localhost:3000

# Revalidation secret (must match frontend .env)
REVALIDATION_SECRET=your_revalidation_secret_here
