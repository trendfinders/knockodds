# ===========================================
# UFC Best Site - Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# API-Sports MMA
API_SPORTS_KEY=your_api_sports_key_here

# WordPress Headless CMS
WP_URL=http://localhost:8080
WP_API_USER=admin
WP_API_PASSWORD=your_wordpress_password
WP_JWT_SECRET=your_jwt_secret_key

# OpenAI (GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key

# Cloudflare R2 (Image CDN)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=ufc-best-site-media
R2_PUBLIC_URL=https://media.knockodds.com

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXX

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id

# ISR Revalidation
REVALIDATION_SECRET=generate_a_random_secret_here
CRON_SECRET=generate_another_random_secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Affiliate Postback
AFFILIATE_POSTBACK_SECRET=generate_a_random_hmac_secret

# Site URL
NEXT_PUBLIC_SITE_URL=https://knockodds.com
